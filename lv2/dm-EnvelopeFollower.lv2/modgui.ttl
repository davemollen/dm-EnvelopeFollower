@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://github.com/davemollen/dm-EnvelopeFollower>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-dm-envelopefollower.html> ;
        modgui:stylesheet <modgui/stylesheet-dm-envelopefollower.css> ;
        modgui:screenshot <modgui/screenshot-dm-envelopefollower.png> ;
        modgui:thumbnail <modgui/thumbnail-dm-envelopefollower.png> ;
        modgui:javascript <modgui/javascript.js> ;
        modgui:brand "DM" ;
        modgui:label "CV Envelope Follower" ;
        modgui:monitoredOutputs [ lv2:symbol "scope_input" ] ;
        modgui:port [
            lv2:index 0 ;
            lv2:symbol "gain" ;
            lv2:name "Gain" ;
        ] , [
            lv2:index 1 ;
            lv2:symbol "mode" ;
            lv2:name "Mode" ;
        ] , [
            lv2:index 2 ;
            lv2:symbol "rise" ;
            lv2:name "Rise" ;
        ] , [
            lv2:index 3 ;
            lv2:symbol "fall" ;
            lv2:name "Fall" ;
        ] , [
            lv2:index 4 ;
            lv2:symbol "invert_cv_output" ;
            lv2:name "Invert Output" ;
        ] ;
    ] .